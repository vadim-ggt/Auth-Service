<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260203-3" author="vadim-ggt">
        <comment>Add foreign key fk_refresh_tokens_credentials from refresh_tokens.user_id to credentials.user_id</comment>

        <addForeignKeyConstraint
                baseTableName="refresh_tokens"
                baseColumnNames="user_id"
                referencedTableName="credentials"
                referencedColumnNames="user_id"
                constraintName="fk_refresh_tokens_credentials"
                onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>
